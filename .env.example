# Gemini API Key (Optional: users can enter their own key in Settings)
VITE_GEMINI_API_KEY=

# Firebase Auth Configuration (Required for Google Login)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# Test-only override to bypass auth gate in workspace smoke profile
VITE_DISABLE_FIREBASE_AUTH=false

# Supabase (Required for cloud project storage / cross-device sync)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Data provider mode (safe default = client)
VITE_DATA_PROVIDER=client
VITE_PROXY_PROJECTS_URL=/api/projects
VITE_DATA_PROVIDER_SHADOW_READ=true
VITE_DATA_PROVIDER_FALLBACK_CLIENT=false

# UI V2 Rollout Flags (all optional, additive)
VITE_UI_V2_ENABLED=false
VITE_UI_V2_CANARY_PERCENT=0
VITE_UI_V2_ONBOARDING=true
VITE_UI_V2_MONITOR=true
VITE_UI_V2_ASSETS=true
VITE_UI_V2_HISTORY=true
# Performance add-ons (optional, additive)
VITE_UI_PERF_V1=true
VITE_UI_V2_VIRTUAL_LISTS=false
# External analytics adapter (optional, additive)
VITE_ANALYTICS_EXTERNAL_V1=false
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# Firebase Admin credentials for /api proxy verification
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Use literal \n in env value if configured via dashboard/CI
FIREBASE_ADMIN_PRIVATE_KEY=
