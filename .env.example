# Gemini API Key (Optional: users can enter their own key in Settings)
VITE_GEMINI_API_KEY=

# Firebase Auth Configuration (Required for Google Login)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Supabase (Required for cloud project storage / cross-device sync)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# UI V2 Rollout Flags (all optional, additive)
VITE_UI_V2_ENABLED=false
VITE_UI_V2_CANARY_PERCENT=0
VITE_UI_V2_ONBOARDING=true
VITE_UI_V2_MONITOR=true
VITE_UI_V2_ASSETS=true
VITE_UI_V2_HISTORY=true
