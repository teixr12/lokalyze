{
  "name": "lokalyze.site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "perf:budget": "node scripts/check-bundle-budget.mjs",
    "audit:analytics-drift": "node scripts/audit-analytics-drift.mjs",
    "preview": "vite preview",
    "smoke:prod": "bash scripts/smoke-prod.sh",
    "smoke:local": "BASE_URL=http://127.0.0.1:4173 bash scripts/smoke-prod.sh",
    "release:checklist": "cat docs/release-checklist.md",
    "test:smoke:public": "PLAYWRIGHT_PROFILE=public playwright test tests/smoke.public.spec.ts",
    "test:smoke:workspace": "VITE_DISABLE_FIREBASE_AUTH=true PLAYWRIGHT_PROFILE=workspace playwright test tests/smoke.workspace.spec.ts",
    "test:smoke:all": "npm run test:smoke:public && npm run test:smoke:workspace",
    "test:smoke": "npm run test:smoke:all"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@monaco-editor/react": "^4.7.0",
    "@supabase/supabase-js": "^2.98.0",
    "file-saver": "2.0.5",
    "firebase": "^11.10.0",
    "firebase-admin": "^13.7.0",
    "jszip": "3.10.1",
    "posthog-js": "^1.357.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
